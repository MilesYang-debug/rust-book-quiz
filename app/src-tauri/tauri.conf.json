{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rust Book Quiz",
  "version": "0.1.0",
  "identifier": "com.rustbookquiz.app",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Rust Book Quiz — The Rust Programming Language",
        "width": 1240,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "center": true,
        "decorations": false,
        "backgroundColor": "#090c13"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "category": "Education",
    "shortDescription": "Quiz app for The Rust Programming Language (the Rust Book)"
  }
}
