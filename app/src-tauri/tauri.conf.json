{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rust Book Quiz",
  "version": "0.1.0",
  "identifier": "com.rustbookquiz.app",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Rust Book Quiz — The Rust Programming Language",
        "width": 1240,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
